---
import Layout from '@/layouts/Layout.astro';
import { pages } from '@/content/pages';
import { galleryItems, getGalleryTags } from '@/content/gallery';

const p = pages.gallery.it;
const tags = getGalleryTags();
const currentTag = Astro.url.searchParams.get('tag');
const filteredItems = currentTag
  ? galleryItems.filter(item => item.tags.includes(currentTag))
  : galleryItems;
---

<Layout
  title={p.seo.title}
  description={p.seo.description}
  image={p.seo.image}
  locale="it"
>
  <!-- ═══ HERO ═══ -->
  <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden" data-dynamic-slider="hero">
    <div class="absolute inset-0" data-hero-images>
      <img
        src={p.hero.image}
        alt={p.hero.title}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/30 to-black/50"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <div class="line-accent mx-auto mb-8 opacity-80"></div>
      <h1 class="font-display text-4xl md:text-6xl font-light tracking-wide mb-4 text-shadow-elegant">
        {p.hero.title}
      </h1>
      {p.hero.description && (
        <p class="text-lg font-body font-light text-white/70 max-w-2xl mx-auto leading-relaxed">
          {p.hero.description}
        </p>
      )}
    </div>
  </section>

  <!-- ═══ GALLERY GRID ═══ -->
  <section class="section-padding bg-dotted">
    <div class="container mx-auto px-4">
      <!-- Griglia dinamica: se ci sono immagini in Supabase, sostituisce i fallback statici -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" data-dynamic-gallery="all">
        {filteredItems.map((item) => (
          <div class="location-card group rounded-sm overflow-hidden bg-muted">
            <img
              src={item.src}
              alt={item.alt.it}
              class="w-full h-64 object-cover"
              loading="lazy"
              width={item.width}
              height={item.height}
            />
            <div class="location-card-overlay flex items-end p-5">
              <div>
                <p class="text-white text-sm font-body font-medium mb-2">{item.caption.it}</p>
                <div class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <span class="text-[10px] uppercase tracking-wider bg-white/15 text-white/80 px-2 py-0.5 rounded-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {filteredItems.length === 0 && (
        <div class="text-center py-16">
          <p class="text-muted-foreground font-body">Nessuna immagine trovata per questo filtro.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-primary"></div>
    <div class="absolute inset-0 bg-dotted opacity-10"></div>
    <div class="relative z-10 container mx-auto px-4 text-center">
      <div class="line-accent mx-auto mb-8" style="background-color:hsl(var(--accent))"></div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-white font-light tracking-wide mb-6">
        Ispirati per il Tuo Evento
      </h2>
      <p class="text-white/70 font-body text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
        Scopri come Villa Paris può rendere il tuo giorno indimenticabile.
      </p>
      <a href="/contatti" class="btn-elegant border-white/60 text-white hover:bg-white hover:text-primary">
        Richiedi Disponibilità
      </a>
    </div>
  </section>
</Layout>
