---
import Layout from '@/layouts/Layout.astro';
import { pages } from '@/content/pages';

const p = pages.contacts.it;
---

<Layout
  title={p.seo.title}
  description={p.seo.description}
  image={p.seo.image}
  locale="it"
>
  <!-- ═══ HERO ═══ -->
  <section class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={p.hero.image}
        alt={p.hero.title}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/30 to-black/50"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <div class="line-accent mx-auto mb-8 opacity-80"></div>
      <h1 class="font-display text-4xl md:text-6xl font-light tracking-wide mb-4 text-shadow-elegant">
        {p.hero.title}
      </h1>
      {p.hero.description && (
        <p class="text-lg font-body font-light text-white/70 max-w-2xl mx-auto leading-relaxed">
          {p.hero.description}
        </p>
      )}
    </div>
  </section>

  <!-- ═══ CONTACT INFO + FORM ═══ -->
  <section class="section-padding bg-dotted">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-16">

        <!-- Info column -->
        <div class="lg:col-span-2">
          <div class="line-accent mb-6"></div>
          <h2 class="section-title text-2xl md:text-3xl mb-6">Rimaniamo in Contatto</h2>
          <p class="text-muted-foreground font-body mb-10 leading-relaxed">
            Siamo a disposizione per rispondere a ogni vostra domanda e aiutarvi a pianificare il vostro evento perfetto.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:hsl(var(--accent)/0.15)">
                <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3 class="font-display text-base mb-1">Indirizzo</h3>
                <p class="text-muted-foreground text-sm font-body">Via Acquaviva, 11<br/>64026 Roseto degli Abruzzi (TE)</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:hsl(var(--accent)/0.15)">
                <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h3 class="font-display text-base mb-1">Telefono</h3>
                <a href="tel:+390858937706" class="text-muted-foreground text-sm font-body hover:text-accent transition-colors">+39 085 8937706</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:hsl(var(--accent)/0.15)">
                <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h3 class="font-display text-base mb-1">Email</h3>
                <a href="mailto:info@villaparis.it" class="text-muted-foreground text-sm font-body hover:text-accent transition-colors">info@villaparis.it</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Form column -->
        <div class="lg:col-span-3">
          <div class="bg-card p-8 lg:p-10 rounded-sm border border-border/50" style="box-shadow:var(--shadow-card)">
            <h3 class="font-display text-xl mb-6">Richiedi Informazioni</h3>

            <form action="/contatti/grazie" method="GET" class="space-y-5">
              <!-- Honeypot -->
              <div class="hidden" aria-hidden="true">
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Nome e Cognome *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors" />
                </div>
                <div>
                  <label for="email" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Email *</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="phone" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Telefono</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors" />
                </div>
                <div>
                  <label for="event-type" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Tipo di Evento *</label>
                  <select id="event-type" name="event-type" required class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors">
                    <option value="">Seleziona...</option>
                    <option value="matrimonio">Matrimonio</option>
                    <option value="evento-privato">Evento Privato</option>
                    <option value="evento-aziendale">Evento Aziendale</option>
                    <option value="altro">Altro</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="event-date" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Data Evento</label>
                <input type="date" id="event-date" name="event-date" class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="message" class="block text-xs uppercase tracking-wider text-muted-foreground mb-2 font-medium">Messaggio *</label>
                <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 bg-background border border-border rounded-sm text-sm font-body focus:outline-none focus:border-accent transition-colors resize-vertical"></textarea>
              </div>

              <div class="flex items-start gap-2">
                <input type="checkbox" id="privacy" name="privacy" required class="mt-1 accent-accent" />
                <label for="privacy" class="text-xs text-muted-foreground font-body leading-relaxed">
                  Autorizzo il trattamento dei dati personali ai sensi del GDPR *
                </label>
              </div>

              <button type="submit" class="btn-primary w-full text-center">
                Invia Messaggio
              </button>
            </form>

            <p class="text-xs text-muted-foreground mt-4 font-body">
              * Campi obbligatori. I tuoi dati saranno trattati in conformità con la nostra privacy policy.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MAP ═══ -->
  <section class="section-padding bg-secondary">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="line-accent mx-auto mb-6"></div>
        <h2 class="section-title text-2xl md:text-3xl mb-4">Dove Siamo</h2>
        <p class="text-muted-foreground font-body">Villa Paris si trova nel cuore di Roseto degli Abruzzi.</p>
      </div>

      <div class="max-w-4xl mx-auto bg-muted h-96 rounded-sm flex items-center justify-center border border-border/50">
        <div class="text-center px-4">
          <svg class="w-12 h-12 mx-auto mb-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <p class="text-muted-foreground font-body mb-3">Via Acquaviva, 11 - Roseto degli Abruzzi (TE)</p>
          <a
            href="https://maps.google.com/?q=Villa+Paris+Roseto+degli+Abruzzi"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-elegant text-xs"
          >
            Apri in Google Maps
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
