---
import { globalSettings } from '@/content/settings';

export interface Props {
  locale: 'it' | 'en';
}

const { locale } = Astro.props;
const settings = globalSettings;
const navigation = locale === 'it' ? settings.navigation.it : settings.navigation.en;
const currentPath = Astro.url.pathname;

/* Split nav in two halves around the logo */
const mid = Math.ceil(navigation.length / 2);
const navLeft  = navigation.slice(0, mid);
const navRight = navigation.slice(mid);
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-700"
>
  <!-- Desktop bar -->
  <div
    id="header-inner"
    class="transition-all duration-700 mx-0 mt-0 bg-transparent"
  >
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between h-20 lg:h-24">

        <!-- Left nav (desktop) -->
        <nav class="hidden lg:flex items-center flex-1 justify-end">
          {navLeft.map((item) => (
            <a
              href={item.href}
              class:list={[
                'nav-link-header relative px-4 xl:px-5 py-6 text-[11px] xl:text-xs tracking-[0.25em] font-medium transition-all duration-500',
                currentPath === item.href
                  ? 'is-active text-white'
                  : 'text-white/70 hover:text-white'
              ]}
            >
              {item.label.toUpperCase()}
              {currentPath === item.href && (
                <span class="absolute bottom-4 left-4 right-4 h-[1px] bg-accent block"></span>
              )}
            </a>
          ))}
        </nav>

        <!-- Center logo -->
        <a
          href={locale === 'it' ? '/' : '/en'}
          class="flex items-center gap-3 lg:mx-10 xl:mx-14 flex-shrink-0"
        >
          <div
            id="logo-circle"
            class="w-11 h-11 lg:w-14 lg:h-14 rounded-full flex items-center justify-center transition-all duration-500 bg-white/15 backdrop-blur-sm border border-white/30"
          >
            <span
              id="logo-text"
              class="font-display text-lg lg:text-xl transition-colors duration-500 text-white"
            >VP</span>
          </div>
          <span
            id="logo-name"
            class="font-display text-xl lg:text-2xl tracking-wide transition-colors duration-500 hidden sm:block text-white"
          >Villa Paris</span>
        </a>

        <!-- Right nav (desktop) -->
        <nav class="hidden lg:flex items-center flex-1">
          {navRight.map((item) => (
            <a
              href={item.href}
              class:list={[
                'nav-link-header relative px-4 xl:px-5 py-6 text-[11px] xl:text-xs tracking-[0.25em] font-medium transition-all duration-500',
                currentPath === item.href
                  ? 'is-active text-white'
                  : 'text-white/70 hover:text-white'
              ]}
            >
              {item.label.toUpperCase()}
              {currentPath === item.href && (
                <span class="absolute bottom-4 left-4 right-4 h-[1px] bg-accent block"></span>
              )}
            </a>
          ))}

          <!-- Language switcher desktop -->
          <a
            href={locale === 'it'
              ? '/en' + (currentPath === '/' ? '' : currentPath)
              : (currentPath.replace('/en', '') || '/')}
            class="ml-6 pl-6 border-l border-white/20 text-[11px] tracking-[0.2em] text-white/50 hover:text-white transition-colors duration-300"
          >
            {locale === 'it' ? 'EN' : 'IT'}
          </a>
        </nav>

        <!-- Mobile menu button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-white hover:text-white/80 transition-colors"
          aria-label="Toggle menu"
        >
          <span id="menu-icon-open" class="block">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </span>
          <span id="menu-icon-close" class="hidden">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden mx-4 mt-2 rounded-lg border border-white/10 shadow-2xl overflow-hidden"
    style="background:hsl(30,10%,12%)"
  >
    <nav class="px-6 py-6">
      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3.5 text-sm tracking-[0.25em] font-medium border-b border-white/10 last:border-0',
            currentPath === item.href ? 'text-accent' : 'text-white/90'
          ]}
        >
          {item.label.toUpperCase()}
        </a>
      ))}
      <div class="mt-6 pt-4 border-t border-white/10 space-y-3">
        <a href="tel:+390858937706" class="flex items-center gap-3 text-sm text-white/60 hover:text-accent transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>085 8937706</span>
        </a>
        <a href="mailto:info@villaparis.it" class="flex items-center gap-3 text-sm text-white/60 hover:text-accent transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>info@villaparis.it</span>
        </a>
      </div>
      <div class="mt-4 pt-4 border-t border-white/10">
        <a
          href={locale === 'it'
            ? '/en' + (currentPath === '/' ? '' : currentPath)
            : (currentPath.replace('/en', '') || '/')}
          class="text-sm text-white/50 hover:text-accent transition-colors"
        >
          {locale === 'it' ? 'English' : 'Italiano'}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  /* Header scroll effect + mobile menu toggle (progressive enhancement) */
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('site-header');
    const inner  = document.getElementById('header-inner');
    const logoCircle = document.getElementById('logo-circle');
    const logoText   = document.getElementById('logo-text');
    const logoName   = document.getElementById('logo-name');
    const navLinks   = document.querySelectorAll('.nav-link-header');
    const mobileBtn  = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen   = document.getElementById('menu-icon-open');
    const iconClose  = document.getElementById('menu-icon-close');

    let scrolled = false;

    function updateHeader() {
      const isScrolled = window.scrollY > 80;
      if (isScrolled === scrolled) return;
      scrolled = isScrolled;

      if (isScrolled) {
        inner.classList.add('mx-4', 'lg:mx-8', 'mt-3', 'rounded-lg', 'border', 'border-border/60', 'bg-background/95', 'backdrop-blur-md');
        inner.classList.remove('mx-0', 'mt-0', 'bg-transparent');
        inner.style.boxShadow = 'var(--shadow-elegant)';
        logoCircle.classList.remove('bg-white/15', 'backdrop-blur-sm', 'border', 'border-white/30');
        logoCircle.classList.add('bg-primary');
        logoText.classList.remove('text-white');
        logoText.classList.add('text-primary-foreground');
        logoName.classList.remove('text-white');
        logoName.classList.add('text-primary');
        navLinks.forEach(link => {
          if (link.classList.contains('is-active')) {
            link.classList.remove('text-white');
            link.classList.add('text-accent');
          } else {
            link.classList.remove('text-white/70', 'hover:text-white');
            link.classList.add('text-foreground/70', 'hover:text-accent');
          }
        });
      } else {
        inner.classList.remove('mx-4', 'lg:mx-8', 'mt-3', 'rounded-lg', 'border', 'border-border/60', 'bg-background/95', 'backdrop-blur-md');
        inner.classList.add('mx-0', 'mt-0', 'bg-transparent');
        inner.style.boxShadow = '';
        logoCircle.classList.add('bg-white/15', 'backdrop-blur-sm', 'border', 'border-white/30');
        logoCircle.classList.remove('bg-primary');
        logoText.classList.add('text-white');
        logoText.classList.remove('text-primary-foreground');
        logoName.classList.add('text-white');
        logoName.classList.remove('text-primary');
        navLinks.forEach(link => {
          if (link.classList.contains('is-active')) {
            link.classList.add('text-white');
            link.classList.remove('text-accent');
          } else {
            link.classList.add('text-white/70', 'hover:text-white');
            link.classList.remove('text-foreground/70', 'hover:text-accent');
          }
        });
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();

    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener('click', () => {
        const open = mobileMenu.classList.toggle('hidden');
        iconOpen.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
      });
    }
  });
</script>
